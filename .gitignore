# ============================================
backend/uploads/logos/*
backend/uploads/covers/*
backend/uploads/resumes/*
!backend/uploads/.gitkeep

# ============================================
# Go specific
# ============================================
backend/backend
backend/backend.exe
*.test

# ============================================
# Frontend specific
# ============================================
frontend/dist/
frontend/.vite/
frontend/coverage/

# ============================================
