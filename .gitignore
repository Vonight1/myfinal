# ============================================
# Dependencies
# ============================================
node_modules/
*/node_modules/
vendor/

# ============================================
# Build outputs
# ============================================
dist/
build/
*.exe
*.dll

# ============================================
# Environment variables (SECRET!)
# ============================================
.env
.env.local
.env.production
.env.*.local
backend/.env
!.env.example

# ============================================
# IDE / Editor
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
# Logs
# ============================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ============================================
