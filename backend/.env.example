# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=parttime_job_db

# ============================================
# JWT Secret (ສຳຄັນ! ປ່ຽນເປັນ random string)
# ສ້າງດ້ວຍ: openssl rand -base64 32
# ============================================
JWT_SECRET=change-this-to-random-secret-key-in-production

# ============================================
# Admin Creation Secret Key
# ============================================
ADMIN_SECRET=change-this-admin-secret

# ============================================
# Server Configuration
# ============================================
PORT=8080
